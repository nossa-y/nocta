#!/usr/bin/env python3
"""
Nocta CLI — Control the Nocta context service.

Usage:
    nocta start       Start the daemon (and recorder if not running)
    nocta stop        Stop the daemon
    nocta restart     Restart the daemon
    nocta status      Show service status
    nocta context     Show current context (what you're doing right now)
    nocta logs        Show recent logs
    nocta install     Set up LaunchAgent for auto-start
    nocta uninstall   Remove LaunchAgent
    nocta version     Show version
"""
import json
import os
import signal
import subprocess
import sys
import time
import urllib.request

VERSION = "0.1.0"
NOCTA_HOME = os.path.expanduser("~/.nocta")
PID_PATH = os.path.join(NOCTA_HOME, "cache", "daemon.pid")
LOG_PATH = os.path.join(NOCTA_HOME, "logs", "daemon.log")
ERROR_LOG_PATH = os.path.join(NOCTA_HOME, "logs", "daemon.error.log")
PLIST_LABEL = "com.nocta.daemon"
PLIST_PATH = os.path.expanduser(f"~/Library/LaunchAgents/{PLIST_LABEL}.plist")
DAEMON_PATH = os.path.join(NOCTA_HOME, "lib", "daemon.py")
PORT = 7676
RECORDER_CMD = "screenpipe"


def get_python():
    """Find a working Python 3."""
    for p in [sys.executable, "python3", "/usr/bin/python3", "/opt/homebrew/bin/python3"]:
        try:
            result = subprocess.run([p, "--version"], capture_output=True, text=True, timeout=5)
            if result.returncode == 0 and "Python 3" in result.stdout:
                return p
        except Exception:
            continue
    return "python3"


def get_pid():
    """Get daemon PID — try PID file first, fall back to port check."""
    # Method 1: PID file
    try:
        with open(PID_PATH) as f:
            pid = int(f.read().strip())
        os.kill(pid, 0)  # Check if alive
        return pid
    except (FileNotFoundError, ValueError, ProcessLookupError, PermissionError):
        pass

    # Method 2: Check if something is listening on the port
    try:
        import urllib.request
        req = urllib.request.urlopen(f"http://127.0.0.1:{PORT}/health", timeout=1)
        data = json.loads(req.read())
        if data.get("status") == "ok":
            # Find the PID via lsof
            result = subprocess.run(
                ["lsof", "-ti", f":{PORT}"], capture_output=True, text=True
            )
            if result.returncode == 0:
                pid = int(result.stdout.strip().split("\n")[0])
                return pid
    except Exception:
        pass

    return None


def is_recorder_running():
    """Check if the screen recorder is running."""
    try:
        result = subprocess.run(["pgrep", "-f", RECORDER_CMD], capture_output=True)
        return result.returncode == 0
    except Exception:
        return False


def start_recorder():
    """Start the screen recorder if not running."""
    if is_recorder_running():
        return True

    # Check if recorder is installed
    result = subprocess.run(["which", RECORDER_CMD], capture_output=True, text=True)
    if result.returncode != 0:
        print(f"  ⚠ Screen recorder not found. Install with: npm install -g {RECORDER_CMD}")
        return False

    print("  Starting screen recorder...", end=" ", flush=True)
    log = open(os.path.join(NOCTA_HOME, "logs", "recorder.log"), "a")
    subprocess.Popen(
        [RECORDER_CMD, "record", "--audio-chunk-duration", "300"],
        stdout=log, stderr=log,
        start_new_session=True,
    )
    time.sleep(2)
    if is_recorder_running():
        print("✓")
        return True
    else:
        print("✗")
        return False


def cmd_stop():
    """Stop the Nocta daemon."""
    # Unload LaunchAgent first to prevent auto-restart
    was_loaded = subprocess.run(
        ["launchctl", "list", PLIST_LABEL], capture_output=True
    ).returncode == 0

    if was_loaded:
        subprocess.run(["launchctl", "unload", PLIST_PATH], capture_output=True)
        time.sleep(1)

    pid = get_pid()
    if not pid and was_loaded:
        print("Stopping Nocta... ✓")
        return

    if not pid:
        print("Nocta is not running")
        return

    print(f"Stopping Nocta (PID {pid})...", end=" ", flush=True)
    try:
        os.kill(pid, signal.SIGTERM)
        for _ in range(10):
            time.sleep(0.3)
            try:
                os.kill(pid, 0)
            except ProcessLookupError:
                print("✓")
                return
        os.kill(pid, signal.SIGKILL)
        print("✓ (forced)")
    except ProcessLookupError:
        print("✓ (already stopped)")
    except Exception as e:
        print(f"✗ ({e})")

    try:
        os.remove(PID_PATH)
    except OSError:
        pass


def cmd_start():
    """Start the Nocta daemon."""
    pid = get_pid()
    if pid:
        print(f"Nocta is already running (PID {pid})")
        return

    os.makedirs(os.path.join(NOCTA_HOME, "logs"), exist_ok=True)
    os.makedirs(os.path.join(NOCTA_HOME, "cache"), exist_ok=True)

    start_recorder()

    print("  Starting Nocta daemon...", end=" ", flush=True)
    
    # Try LaunchAgent first (preferred — auto-restarts on crash)
    if os.path.exists(PLIST_PATH):
        subprocess.run(["launchctl", "load", PLIST_PATH], capture_output=True)
        subprocess.run(["launchctl", "start", PLIST_LABEL], capture_output=True)
    else:
        # Direct start fallback
        python = get_python()
        log = open(LOG_PATH, "a")
        err = open(ERROR_LOG_PATH, "a")
        subprocess.Popen(
            [python, DAEMON_PATH],
            stdout=log, stderr=err,
            start_new_session=True,
            cwd=NOCTA_HOME,
        )

    for i in range(15):
        time.sleep(0.5)
        try:
            req = urllib.request.urlopen(f"http://127.0.0.1:{PORT}/health", timeout=2)
            data = json.loads(req.read())
            if data.get("status") == "ok":
                print("✓")
                print(f"  Context API: http://127.0.0.1:{PORT}/context")
                return
        except Exception:
            pass

    if get_pid():
        print("✓ (slow start)")
        print(f"  Context API: http://127.0.0.1:{PORT}/context")
    else:
        print("✗")
        print(f"  Check logs: nocta logs")


def cmd_restart():
    """Restart the daemon."""
    cmd_stop()
    time.sleep(1)
    cmd_start()


def cmd_status():
    """Show service status."""
    pid = get_pid()
    recorder = is_recorder_running()

    print(f"Nocta v{VERSION}")
    print(f"  Daemon:   {'running (PID ' + str(pid) + ')' if pid else 'stopped'}")
    print(f"  Recorder: {'running' if recorder else 'stopped'}")

    if pid:
        try:
            req = urllib.request.urlopen(f"http://127.0.0.1:{PORT}/status", timeout=2)
            data = json.loads(req.read())
            print(f"  Uptime:   {data.get('uptime_seconds', 0):.0f}s")
            print(f"  Task:     {data.get('current_task', 'unknown')}")
            print(f"  State:    {data.get('behavioral_state', 'unknown')}")
            print(f"  Last update: {data.get('last_update', 'never')}")
        except Exception:
            print("  API:      not responding")


def cmd_context():
    """Show current context."""
    try:
        req = urllib.request.urlopen(f"http://127.0.0.1:{PORT}/context", timeout=2)
        data = json.loads(req.read())
        print(json.dumps(data, indent=2))
    except Exception as e:
        print(f"Error: Cannot reach Nocta daemon ({e})")
        print("Run 'nocta start' first.")
        sys.exit(1)


def cmd_logs():
    """Show recent logs."""
    for path, label in [(LOG_PATH, "daemon"), (ERROR_LOG_PATH, "errors")]:
        if os.path.exists(path):
            size = os.path.getsize(path)
            if size > 0:
                print(f"=== {label} (last 30 lines) ===")
                with open(path) as f:
                    lines = f.readlines()
                    for line in lines[-30:]:
                        print(line.rstrip())
                print()


def cmd_install():
    """Install LaunchAgent for auto-start on login."""
    python = get_python()
    plist = f"""<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>{PLIST_LABEL}</string>
    <key>ProgramArguments</key>
    <array>
        <string>{python}</string>
        <string>{DAEMON_PATH}</string>
    </array>
    <key>WorkingDirectory</key>
    <string>{NOCTA_HOME}</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>
    <key>StandardOutPath</key>
    <string>{LOG_PATH}</string>
    <key>StandardErrorPath</key>
    <string>{ERROR_LOG_PATH}</string>
    <key>ThrottleInterval</key>
    <integer>10</integer>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin:{os.path.dirname(python)}</string>
    </dict>
</dict>
</plist>"""

    os.makedirs(os.path.dirname(PLIST_PATH), exist_ok=True)
    with open(PLIST_PATH, "w") as f:
        f.write(plist)

    subprocess.run(["launchctl", "load", PLIST_PATH], capture_output=True)
    print(f"✓ LaunchAgent installed: {PLIST_PATH}")
    print("  Nocta will auto-start on login")


def cmd_uninstall():
    """Remove LaunchAgent."""
    subprocess.run(["launchctl", "unload", PLIST_PATH], capture_output=True)
    try:
        os.remove(PLIST_PATH)
        print("✓ LaunchAgent removed")
    except FileNotFoundError:
        print("LaunchAgent not found")


def cmd_version():
    print(f"nocta {VERSION}")


def cmd_doctor():
    """Diagnose Nocta setup — check recorder, permissions, data flow."""
    print(f"Nocta Doctor v{VERSION}")
    print("=" * 40)
    issues = []

    # 1. Check if screenpipe is installed
    result = subprocess.run(["which", "screenpipe"], capture_output=True, text=True)
    if result.returncode == 0:
        print(f"  ✓ Screen recorder installed: {result.stdout.strip()}")
    else:
        print("  ✗ Screen recorder not found")
        issues.append("Install with: npm install -g screenpipe")

    # 2. Run screenpipe doctor
    try:
        result = subprocess.run(["screenpipe", "doctor"], capture_output=True, text=True, timeout=10)
        for line in result.stdout.strip().split("\n"):
            line = line.strip()
            if not line or line.startswith("screenpipe") or line.startswith("==="):
                continue
            if "ok" in line.lower():
                print(f"  ✓ {line}")
            elif "error" in line.lower() or "fail" in line.lower() or "not" in line.lower():
                print(f"  ✗ {line}")
                issues.append(line)
            else:
                print(f"  · {line}")
    except FileNotFoundError:
        print("  ✗ Cannot run screenpipe doctor")
    except Exception as e:
        print(f"  ⚠ screenpipe doctor: {e}")

    # 3. Check if recorder is running
    if is_recorder_running():
        print("  ✓ Screen recorder process running")
    else:
        print("  ✗ Screen recorder not running")
        issues.append("Start with: nocta start")

    # 4. Check recorder DB
    db_path = None
    try:
        result = subprocess.run(["screenpipe", "status"], capture_output=True, text=True, timeout=5)
        for line in result.stdout.split("\n"):
            if "data dir:" in line.lower():
                data_dir = line.split(":", 1)[1].strip()
                db_path = os.path.join(data_dir, "db.sqlite")
    except Exception:
        pass

    if not db_path:
        db_path = os.path.expanduser("~/.screenpipe/db.sqlite")

    if os.path.exists(db_path):
        size_mb = os.path.getsize(db_path) / (1024 * 1024)
        print(f"  ✓ Database found: {db_path} ({size_mb:.1f} MB)")

        # Check if DB has recent data
        try:
            import sqlite3
            db = sqlite3.connect(db_path, timeout=5)
            count = db.execute(
                "SELECT COUNT(*) FROM frames WHERE timestamp > datetime('now', '-5 minutes')"
            ).fetchone()[0]
            db.close()
            if count > 0:
                print(f"  ✓ Recent data: {count} frames in last 5 minutes")
            else:
                print("  ✗ No recent frames — recorder may not be capturing")
                issues.append("Screen recording permission may not be granted")
        except Exception as e:
            print(f"  ⚠ Cannot query DB: {e}")
    else:
        print(f"  ✗ Database not found at {db_path}")
        issues.append("Recorder hasn't created database yet — start recording first")

    # 5. Check Nocta daemon
    pid = get_pid()
    if pid:
        print(f"  ✓ Nocta daemon running (PID {pid})")
    else:
        print("  ✗ Nocta daemon not running")
        issues.append("Start with: nocta start")

    # 6. Check API
    try:
        req = urllib.request.urlopen(f"http://127.0.0.1:{PORT}/health", timeout=2)
        data = json.loads(req.read())
        print(f"  ✓ API responding on port {PORT}")
    except Exception:
        print(f"  ✗ API not responding on port {PORT}")

    # 7. Check context data quality
    try:
        req = urllib.request.urlopen(f"http://127.0.0.1:{PORT}/context", timeout=2)
        ctx = json.loads(req.read())
        frames = ctx.get("meta", {}).get("frames_analyzed", 0)
        state = ctx.get("current_state", {}).get("behavioral_state", "unknown")
        if frames > 0:
            print(f"  ✓ Context working: {frames} frames, state: {state}")
        else:
            print(f"  ⚠ Context empty: 0 frames, state: {state}")
            if ctx.get("diagnostics"):
                issues.append(ctx["diagnostics"].get("issue", ""))
    except Exception:
        pass

    # Summary
    print()
    if issues:
        print(f"  {len(issues)} issue(s) found:")
        for issue in issues:
            print(f"    → {issue}")
    else:
        print("  All checks passed ✓")


def cmd_link():
    """Link Nocta context into the current project for OpenCode/Cursor."""
    integrations = os.path.join(NOCTA_HOME, "integrations")
    linked = []

    for name in ["opencode.md", "CLAUDE.md", "AGENTS.md"]:
        src = os.path.join(integrations, name)
        dst = os.path.join(os.getcwd(), name)
        if os.path.exists(src) and not os.path.exists(dst):
            os.symlink(src, dst)
            linked.append(name)

    if linked:
        print(f"✓ Linked: {', '.join(linked)}")
        print("  These files tell your AI agent to use Nocta context.")
        print("  Add them to .gitignore if you don't want to commit them.")
    else:
        print("Already linked (or integration files missing)")


def cmd_update():
    """Update Nocta to the latest version."""
    REPO = "https://raw.githubusercontent.com/nossa-y/nocta/main"
    print("Updating Nocta...", flush=True)

    # Stop daemon
    was_running = get_pid() is not None
    if was_running:
        cmd_stop()
        time.sleep(1)

    # Download latest files
    import urllib.request
    try:
        for src, dst in [
            (f"{REPO}/daemon.py", DAEMON_PATH),
            (f"{REPO}/nocta-cli", os.path.join(NOCTA_HOME, "bin", "nocta")),
            (f"{REPO}/hermes-skill.md", os.path.join(NOCTA_HOME, "integrations", "hermes-skill.md")),
            (f"{REPO}/CLAUDE.md", os.path.join(NOCTA_HOME, "integrations", "CLAUDE.md")),
            (f"{REPO}/opencode.md", os.path.join(NOCTA_HOME, "integrations", "opencode.md")),
            (f"{REPO}/AGENTS.md", os.path.join(NOCTA_HOME, "integrations", "AGENTS.md")),
        ]:
            urllib.request.urlretrieve(src, dst)
        os.chmod(os.path.join(NOCTA_HOME, "bin", "nocta"), 0o755)
        print("✓ Updated")
    except Exception as e:
        print(f"✗ Update failed: {e}")
        return

    # Restart if was running
    if was_running:
        cmd_start()


def main():
    if len(sys.argv) < 2:
        print(__doc__)
        sys.exit(0)

    cmd = sys.argv[1]
    commands = {
        "start": cmd_start,
        "stop": cmd_stop,
        "restart": cmd_restart,
        "status": cmd_status,
        "context": cmd_context,
        "logs": cmd_logs,
        "install": cmd_install,
        "uninstall": cmd_uninstall,
        "update": cmd_update,
        "link": cmd_link,
        "doctor": cmd_doctor,
        "version": cmd_version,
        "daemon": lambda: __import__("importlib").import_module("daemon").main(),
    }

    if cmd in commands:
        commands[cmd]()
    else:
        print(f"Unknown command: {cmd}")
        print("Run 'nocta' for usage.")
        sys.exit(1)


if __name__ == "__main__":
    main()
